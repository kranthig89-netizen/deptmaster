@model DepartmentMaster.Models.DepartmentListViewModel

@{
    ViewData["Title"] = "Department Master";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="row mb-3">
        <div class="col-md-8">
            <h2 class="text-primary">
                <i class="fas fa-building"></i> Department Master
            </h2>
        </div>
        <div class="col-md-4 text-right">
            <span class="badge badge-info mr-3">
                <i class="fas fa-user"></i> Hello @Model.EmployeeCode - @Model.EmployeeName
            </span>
            <a href="/Auth/Logout" class="btn btn-sm btn-danger">
                <i class="fas fa-sign-out-alt"></i> Sign Out
            </a>
        </div>
    </div>

    <!-- Create Button -->
    <div class="row mb-3">
        <div class="col-md-12">
            <button class="btn btn-primary" data-toggle="modal" data-target="#departmentModal" onclick="openCreateModal()">
                <i class="fas fa-plus"></i> Add New Department
            </button>
            <button class="btn btn-success ml-2" onclick="exportData('csv')">
                <i class="fas fa-download"></i> Export CSV
            </button>
            <button class="btn btn-info ml-2" onclick="exportData('excel')">
                <i class="fas fa-file-excel"></i> Export Excel
            </button>
            <button class="btn btn-warning ml-2" onclick="printData()">
                <i class="fas fa-print"></i> Print
            </button>
        </div>
    </div>

    <!-- Search and Filter Section -->
    <div class="card mb-3">
        <div class="card-header bg-light">
            <h5 class="mb-0">Search & Filter</h5>
        </div>
        <div class="card-body">
            <form method="get" id="filterForm" class="form-inline">
                <div class="form-group mr-3 mb-2">
                    <input type="text" name="searchDepartmentCode" placeholder="Dept Code" 
                           class="form-control form-control-sm" value="@Model.SearchDepartmentCode" />
                </div>
                <div class="form-group mr-3 mb-2">
                    <input type="text" name="searchDepartmentName" placeholder="Dept Name" 
                           class="form-control form-control-sm" value="@Model.SearchDepartmentName" />
                </div>
                <div class="form-group mr-3 mb-2">
                    <select name="searchJapanHead" class="form-control form-control-sm">
                        <option value="">-- Japan Head --</option>
                        <option value="Y" @(Model.SearchJapanHead == "Y" ? "selected" : "")>Yes</option>
                        <option value="N" @(Model.SearchJapanHead == "N" ? "selected" : "")>No</option>
                    </select>
                </div>
                <div class="form-group mr-3 mb-2">
                    <select name="searchOffice" class="form-control form-control-sm">
                        <option value="">-- Office --</option>
                        <option value="P" @(Model.SearchOffice == "P" ? "selected" : "")>Direct</option>
                        <option value="O" @(Model.SearchOffice == "O" ? "selected" : "")>Indirect</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary btn-sm mb-2">
                    <i class="fas fa-search"></i> Search
                </button>
                <a href="@Url.Action("Index")" class="btn btn-secondary btn-sm ml-2 mb-2">
                    <i class="fas fa-redo"></i> Reset
                </a>
            </form>
        </div>
    </div>

    <!-- Success/Error Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <!-- DataTable -->
    <div class="table-responsive">
        <table class="table table-striped table-hover" id="departmentTable">
            <thead class="table-dark">
                <tr>
                    <th>
                        <a href="@Url.Action("Index", new { pageNumber = Model.PageNumber, sortColumn = "DepartmentCode", sortDirection = Model.SortDirection == "ASC" ? "DESC" : "ASC" })">
                            Department Code
                            @if (Model.SortColumn == "DepartmentCode")
                            {
                                <i class="fas @(Model.SortDirection == "ASC" ? "fa-arrow-up" : "fa-arrow-down")"></i>
                            }
                        </a>
                    </th>
                    <th>
                        <a href="@Url.Action("Index", new { pageNumber = Model.PageNumber, sortColumn = "DepartmentName", sortDirection = Model.SortDirection == "ASC" ? "DESC" : "ASC" })">
                            Department Name
                            @if (Model.SortColumn == "DepartmentName")
                            {
                                <i class="fas @(Model.SortDirection == "ASC" ? "fa-arrow-up" : "fa-arrow-down")"></i>
                            }
                        </a>
                    </th>
                    <th>Japan Head</th>
                    <th>Office</th>
                    <th>Section</th>
                    <th>Abbreviation</th>
                    <th>Created By</th>
                    <th>Created On</th>
                    <th>Edited By</th>
                    <th>Edited On</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dept in Model.Departments)
                {
                    <tr>
                        <td>@dept.DepartmentCode</td>
                        <td>@dept.DepartmentName</td>
                        <td>@(dept.JapanHead == "Y" ? "Yes" : "No")</td>
                        <td>@(dept.Office == "P" ? "Direct" : "Indirect")</td>
                        <td>@(dept.Section == "Y" ? "Yes" : "No")</td>
                        <td>@dept.Prefix</td>
                        <td>@dept.CreatedBy</td>
                        <td>@dept.CreatedOn?.ToString("yyyy-MM-dd")</td>
                        <td>@dept.EditedBy</td>
                        <td>@dept.EditedOn?.ToString("yyyy-MM-dd")</td>
                        <td>
                            <button class="btn btn-xs btn-info" onclick="openEditModal(@dept.RecordNo)">
                                <i class="fas fa-edit"></i> Edit
                            </button>
                            <button class="btn btn-xs btn-danger" onclick="deleteDepartment(@dept.RecordNo)">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Departments.Any())
        {
            <div class="alert alert-info">
                No departments found.
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                @if (Model.PageNumber > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { pageNumber = 1 })">First</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { pageNumber = Model.PageNumber - 1 })">Previous</a>
                    </li>
                }

                @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { pageNumber = i })">@i</a>
                    </li>
                }

                @if (Model.PageNumber < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { pageNumber = Model.PageNumber + 1 })">Next</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { pageNumber = Model.TotalPages })">Last</a>
                    </li>
                }
            </ul>
        </nav>

        <div class="text-center mb-3">
            <small class="text-muted">
                Showing @((Model.PageNumber - 1) * Model.PageSize + 1) to @Math.Min(Model.PageNumber * Model.PageSize, Model.TotalRecords) 
                of @Model.TotalRecords records (Page @Model.PageNumber of @Model.TotalPages)
            </small>
        </div>
    }
</div>

<!-- Department Modal -->
<div class="modal fade" id="departmentModal" tabindex="-1" role="dialog" aria-labelledby="departmentModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="departmentModalLabel">Department Details</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div id="modalBody" class="modal-body">
                <!-- Form will be loaded here -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function openCreateModal() {
            $.get('@Url.Action("Create")', function (data) {
                $('#modalBody').html(data);
                $('#departmentModal').modal('show');
            });
        }

        function openEditModal(recordNo) {
            $.get('@Url.Action("Edit")/' + recordNo, function (data) {
                $('#modalBody').html(data);
                $('#departmentModal').modal('show');
            });
        }

        function deleteDepartment(recordNo) {
            if (confirm('Are you sure you want to delete this department?')) {
                $.get('@Url.Action("Delete")/' + recordNo, function (response) {
                    if (response.success) {
                        alert(response.message);
                        location.reload();
                    } else {
                        alert('Error: ' + response.message);
                    }
                });
            }
        }

        function submitForm() {
            var form = $('#departmentForm');
            if (form.valid()) {
                var url = form.attr('action');
                $.ajax({
                    url: url,
                    type: 'POST',
                    data: form.serialize(),
                    success: function (response) {
                        if (response.success) {
                            alert(response.message);
                            $('#departmentModal').modal('hide');
                            location.reload();
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function (xhr) {
                        alert('An error occurred: ' + xhr.statusText);
                    }
                });
            }
        }

        function exportData(format) {
            let action = format === 'csv' ? '@Url.Action("ExportCsv")' : '@Url.Action("ExportExcel")';
            $.post(action, function () {
                window.location.href = action;
            });
        }

        function printData() {
            $.post('@Url.Action("Print")', function (data) {
                var printWindow = window.open('', '', 'width=900,height=600');
                printWindow.document.write(data);
                printWindow.document.close();
                printWindow.print();
            });
        }
    </script>
}